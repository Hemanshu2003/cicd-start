# .env.example
# ─────────────────────────────────────────────────────────────────
# Copy this to .env for local development (never commit .env)
# docker compose automatically reads .env
# ─────────────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://tradingadmin:changeme_local@localhost:5432/trading_signals

# Redis / Celery Broker
REDIS_URL=redis://localhost:6379/0

# App Settings
ENVIRONMENT=local
LOG_LEVEL=debug

# AWS (only needed if running locally against real AWS resources)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
